{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean",
            "group": "build",
            "type": "shell",
            "command": "make clean",
            "options": {
                "statusbar": {
                    "color": "#ff8b8b",
                    "label": "$(clear-all) Clean",
                    "detail": "Clean ALL"
                }
            }
        },
        {
            "label": "build",
            "group": "build",
            "type": "shell",
            "command": "make -j12 BOARD=${config:BOARD} MODE=${config:MODE}",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "color": "#8bff97",
                    "label": "$(code) Build",
                    "detail": "Build"
                }
            }
        },
        {
            "label": "build-debug",
            "group": "build",
            "type": "shell",
            "command": "make -j12 BOARD=${config:BOARD} MODE=debug",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "color": "#ffdd8b",
                    "label": "$(bug) Build Debug",
                    "detail": "Build Debug"
                }
            }
        }
    ]
}