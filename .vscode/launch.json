{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD + ST-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/${config:BOARD}/debug/ceti-whale-tag.elf",
            "configFiles": [
                "${workspaceFolder}/whale-tag-stm32_stm32u595_debug.cfg"
            ],
            "preLaunchTask": "build-debug",
            "device": "STM32U595VJ",
            "runToEntryPoint": "main",
            "gdbPath": "gdb-multiarch",
            "showDevDebugOutput": "none"
        },
        {
            "name": "Attach (OpenOCD + ST-Link)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/${config:BOARD}/debug/ceti-whale-tag.elf",
            "configFiles": [
                "${workspaceFolder}/whale-tag-stm32_stm32u595_debug.cfg"
            ],
            "device": "STM32U595VJ",
            "gdbPath": "gdb-multiarch",
            "showDevDebugOutput": "none"
        }
    ]
}
